{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/quipu/**",
              "motion/**",
              "ui_kits/strand-support/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Spectral|Hanken Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Spectral, Hanken Grotesk, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|actor|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, actor, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='actor'] > Literal[value!=/^(?:user|agent|system)$/]",
        "message": "<Avatar> actor must be one of 'user' | 'agent' | 'system'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|cord|accent|success|warning|danger|info)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'cord' | 'accent' | 'success' | 'warning' | 'danger' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|disabled|onClick|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, disabled, onClick, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|accent|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'accent' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CordGapItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:gap|count|from|to|id|key|ref|className|style|children)$/]",
        "message": "<CordGapItem> doesn't accept that prop. Declared props: gap, count, from, to, id."
      },
      {
        "selector": "JSXOpeningElement[name.name='EntityRefChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|uri|key|ref|className|style|children)$/]",
        "message": "<EntityRefChip> doesn't accept that prop. Declared props: label, uri."
      },
      {
        "selector": "JSXOpeningElement[name.name='GapIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|from|to|onClick|style|key|ref|className|style|children)$/]",
        "message": "<GapIndicator> doesn't accept that prop. Declared props: count, from, to, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PendantCord'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|label|count|icon|active|isNew|variant|onClick|style|key|ref|className|style|children)$/]",
        "message": "<PendantCord> doesn't accept that prop. Declared props: type, label, count, icon, active, isNew, variant, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PendantCord'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:filter|narrative)$/]",
        "message": "<PendantCord> variant must be one of 'filter' | 'narrative'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
